# GNN Node Configuration - Environment Variables

# Node Identity
GNN_NODE_ID=node-a
GNN_API_TOKEN=token_abc123_replace_with_32_plus_chars_here

# Network Ports
GNN_API_PORT=25111
GNN_P2P_PORT=28111

# Bootstrap Peers (comma-separated multiaddrs)
# GNN_BOOTSTRAP_PEERS=/ip4/192.168.1.100/tcp/28111/p2p/Qm...,/ip4/192.168.1.101/tcp/28112/p2p/Qm...

# Storage Paths
GNN_CONFIG_FILE=./gnn-conf-node-a.json
GNN_DB_PATH=./gnn-data-node-a

# Message Settings
GNN_MESSAGE_RETENTION_DAYS=28
GNN_MAX_PAYLOAD_SIZE=31744

# Peer Settings
GNN_PEER_TTL_DAYS=14

# Logging
GNN_LOG_LEVEL=error
# GNN_LOG_FILE=/var/log/gnn/node.log
GNN_LOG_MAX_SIZE_KB=100
GNN_LOG_RETENTION_DAYS=1

# Timeouts
GNN_QUERY_TIMEOUT_MS=100
GNN_BROADCAST_TIMEOUT_MS=1000
