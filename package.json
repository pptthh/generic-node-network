{
  "name": "generic-node-net",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "rm -rf ./gnn-data-* ./.next-* tmp/",
    "start": "bun server.ts",
    "dev": "bun server.ts",
    "gnn:a": "bun server.ts --node-id=node-a --log-level=info",
    "gnn:b": "bun server.ts --node-id=node-b --log-level=error",
    "gnn:c": "bun server.ts --node-id=node-c --log-level=error",
    "gnn3": "bun run gnn:a & bun run gnn:b & bun run gnn:c",
    "build": "bun next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/identify": "^4.1.3",
    "@libp2p/kad-dht": "^16.2.4",
    "@libp2p/mdns": "^12.0.20",
    "@libp2p/ping": "^3.1.3",
    "@libp2p/tcp": "^11.0.18",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "level": "^10.0.0",
    "libp2p": "^3.2.4",
    "next": "^16.2.6",
    "pino": "^10.3.1",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  }
}
