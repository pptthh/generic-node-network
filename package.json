{
  "name": "generic-node-net",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "rm -rf tmp/ ./.next/ && rm -f next-env.d.ts && mkdir ./tmp && git checkout tsconfig.json && echo '\n\ttsconfig.json changes reverted !!!!!!!!!!!!!!\n'",
    "start": "bun server.ts",
    "dev": "bun server.ts",
    "test-start": "bun gnnn & sleep 7 && pkill bun && sleep && bun clean",
    "gnn:a": "bun server.ts --node-id=node-a --log-level=debug",
    "gnn:b": "sleep 10 && bun server.ts --node-id=node-b --log-level=info",
    "gnn:c": "sleep 20 && bun server.ts --node-id=node-c --log-level=warn",
    "gnn:d": "sleep 30 && bun server.ts --node-id=node-d",
    "gnn:e": "sleep 40 && bun server.ts --node-id=node-e",
    "gnnn": "bun gnn:a & bun gnn:b & bun gnn:c & bun gnn:d & bun gnn:e",
    "build": "bun next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "wait": "sleep 10"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bun": "latest",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/autonat": "^3.0.22",
    "@libp2p/circuit-relay-v2": "^4.2.7",
    "@libp2p/dcutr": "^3.0.22",
    "@libp2p/identify": "^4.1.8",
    "@libp2p/kad-dht": "^16.3.3",
    "@libp2p/mdns": "^12.0.25",
    "@libp2p/ping": "^3.1.7",
    "@libp2p/tcp": "^11.0.22",
    "@libp2p/websockets": "^10.1.15",
    "@tailwindcss/postcss": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "fzstd": "^0.1.1",
    "level": "^10.0.0",
    "libp2p": "^3.3.4",
    "nat-api": "^0.3.1",
    "next": "^16.2.9",
    "pino": "^10.3.1",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stun": "^2.1.0",
    "tailwindcss": "^4.3.1",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
